# ==============================================
# WinPawa Frontend - Configuration Example
# ==============================================
# Copy this file to .env and update the values
# ==============================================

# API Configuration
# -----------------
# The base URL for the Laravel backend API
VITE_API_BASE_URL=http://192.168.1.185:8001/api

# Laravel Reverb (WebSocket) Configuration
# -----------------------------------------
# WebSocket configuration for real-time features
# Used for live updates in Virtual Match and notifications
VITE_REVERB_APP_KEY=aurpwd1ffzmlwhfjtyyx
VITE_REVERB_HOST=admin-winpawa.sbs
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# Application Configuration
# --------------------------
# General app settings
VITE_APP_NAME=WinPawa
VITE_APP_URL=https://winpawa.cm

# ==============================================
# Development Configuration (Local)
# ==============================================
# Uncomment these for local development
#
# VITE_API_BASE_URL=http://localhost:8000/api
# VITE_REVERB_HOST=localhost
# VITE_REVERB_PORT=8080
# VITE_REVERB_SCHEME=http
# VITE_APP_URL=http://localhost:3000
